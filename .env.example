# Copy to .env and adjust as needed.

# Host port Deckoala is published on. Point your reverse proxy
# (Caddy / Traefik / Nginx Proxy Manager) for deckoala.dimenshade.com at it.
DECKOALA_PORT=8321

# Allow new account registration (the very first account — the admin —
# can always be created, even when this is false).
DECKOALA_ALLOW_SIGNUP=true

# Set to true when serving over HTTPS so session cookies get the Secure flag.
DECKOALA_SECURE_COOKIE=false

# Public URL of this instance, e.g. https://deckoala.dimenshade.com
# Needed only when your reverse proxy rewrites the Host header.
DECKOALA_PUBLIC_URL=
